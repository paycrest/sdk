{
  "name": "paycrest/sdk-laravel",
  "description": "Official Paycrest Sender SDK v2 for Laravel",
  "type": "library",
  "license": "AGPL-3.0-or-later",
  "autoload": {
    "psr-4": {
      "Paycrest\\SDK\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Paycrest\\SDK\\Tests\\": "tests/"
    }
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Paycrest\\SDK\\PaycrestServiceProvider"
      ],
      "aliases": {
        "Paycrest": "Paycrest\\SDK\\Facades\\Paycrest"
      }
    }
  },
  "require": {
    "php": ">=8.2",
    "illuminate/support": "^12.0"
  },
  "require-dev": {
    "orchestra/testbench": "^10.11",
    "pestphp/pest": "^3.8",
    "pestphp/pest-plugin-laravel": "^3.2",
    "phpunit/phpunit": "11.5.50"
  },
  "scripts": {
    "test": "vendor/bin/pest --colors=always",
    "test:contract": "vendor/bin/pest tests/Contract --colors=always"
  }
}
